b3 <- coef(model_interaction)[4]
cat("b0 =", round(b0, 2), ": Fertility when Agriculture=0 in non-Catholic provinces\n")
cat("b1 =", round(b1, 3), ": Effect of Agriculture in NON-Catholic provinces\n")
cat("b2 =", round(b2, 2), ": Difference in intercept for Catholic provinces\n")
cat("b3 =", round(b3, 3), ": Difference in slope for Catholic provinces\n\n")
cat("CONDITIONAL EFFECTS:\n")
cat("In non-Catholic provinces: Effect of Agriculture =", round(b1, 3), "\n")
cat("In Catholic provinces: Effect of Agriculture =", round(b1 + b3, 3), "\n\n")
# Visualize interaction
p2 <- ggplot(swiss, aes(x = Agriculture, y = Fertility, color = CatholicBin_factor)) +
geom_point(size = 3) +
geom_smooth(method = "lm", se = TRUE) +
labs(title = "With Interaction: Different Slopes",
subtitle = "Agriculture effect depends on religious context",
color = "Religion") +
theme_minimal()
print(p2)
cat("=== CONTINUOUS INTERACTION EXAMPLE ===\n")
cat("What if both variables are continuous?\n")
cat("Using mtcars: Does weight's effect on MPG depend on number of cylinders?\n\n")
data(mtcars)
# Fit interaction model
model_continuous <- lm(mpg ~ wt * cyl, data = mtcars)
summary(model_continuous)
cat("INTERPRETATION:\n")
b0 <- coef(model_continuous)[1]
b1 <- coef(model_continuous)[2]
b2 <- coef(model_continuous)[3]
b3 <- coef(model_continuous)[4]
cat("Effect of weight depends on cylinders:\n")
cat("When cylinders = 4: Effect of weight =", round(b1 + b3*4, 2), "\n")
cat("When cylinders = 6: Effect of weight =", round(b1 + b3*6, 2), "\n")
cat("When cylinders = 8: Effect of weight =", round(b1 + b3*8, 2), "\n\n")
cat("=== VISUALIZING INTERACTIONS ===\n")
# Check if interplot is available, if not provide alternative
if(require(interplot, quietly = TRUE)) {
cat("Using interplot package for interaction visualization:\n")
# Plot marginal effect of Agriculture conditional on Catholic
print(interplot(m = model_interaction, var1 = "Agriculture", var2 = "CatholicBin",
hist = TRUE, point = TRUE) +
ggtitle("Marginal Effect of Agriculture by Catholic Status"))
} else {
cat("interplot package not available. Creating manual visualization:\n")
# Manual calculation of marginal effects
catholic_values <- 0:1
marginal_effects <- sapply(catholic_values, function(x) b1 + b3*x)
effect_df <- data.frame(
Catholic = factor(catholic_values, labels = c("Non-Catholic", "Catholic")),
Effect = marginal_effects
)
p3 <- ggplot(effect_df, aes(x = Catholic, y = Effect)) +
geom_point(size = 4) +
geom_line(group = 1) +
labs(title = "Marginal Effect of Agriculture by Catholic Status",
y = "Effect of Agriculture on Fertility") +
theme_minimal()
print(p3)
}
